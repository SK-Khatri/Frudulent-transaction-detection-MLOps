      "type": "histogram",
      "targets": [
        {
          "expr": "sum(rate(fraud_prediction_probability_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "⚡ Performance",
